msgstr "Var knappen gäller"

#: src/Admin/SettingsPage.php:161
msgid "Applicability"
msgstr "Tillämpningsområde"

#: src/Admin/SettingsPage.php:164
msgid "Only EU/EEA consumers (legal minimum — recommended)"
msgstr "Endast EU/EES-konsumenter (lagstadgat minimum — rekommenderas)"

#: src/Admin/SettingsPage.php:165
