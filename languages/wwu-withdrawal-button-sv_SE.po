msgstr "Varor/tjänster vars pris beror på marknadsfluktuationer som näringsidkaren inte kan kontrollera."

#: src/Domain/ExceptionTypes.php:73
msgid "Alcoholic beverages with delayed, market-linked delivery"
msgstr "Alkoholdrycker med försenad, marknadsknuten leverans"

#: src/Domain/ExceptionTypes.php:73
msgid ""
