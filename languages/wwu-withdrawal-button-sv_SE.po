msgstr "Boende / transport / fritid på ett specifikt datum"

#: src/Domain/ExceptionTypes.php:71
msgid ""
"Accommodation, transport of goods, car rental, catering or leisure services "
"tied to a specific date/period (e.g. dated event tickets, hotel bookings)."
msgstr "Boende, godstransport, biluthyrning, catering eller fritidstjänster knutna till ett specifikt datum/period (t.ex. datumspecifika evenemangsbiljetter, hotellbokningar)."

