msgstr ""

#: src/Admin/SettingsPage.php:527
msgid "e.g. 12, 84"
msgstr ""

#: src/Admin/SettingsPage.php:528
#: src/Admin/SettingsPage.php:542
msgid "Category IDs"
msgstr ""

#: src/Admin/SettingsPage.php:528
msgid "e.g. 5"
msgstr ""

#: src/Admin/SettingsPage.php:531
msgid "How the plugin enforces this:"
msgstr ""

#: src/Admin/SettingsPage.php:531
msgid "on the WooCommerce checkout a required acknowledgement tick-box is added automatically for this reason. The button stays visible until the consumer ticks it; only then is it hidden for this item. On other checkouts/platforms the button stays (fail-safe). For the digital reason you must also deliver a durable-medium (e-mail) confirmation to the consumer before access begins."
msgstr ""

