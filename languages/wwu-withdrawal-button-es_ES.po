msgstr "Acuse de recibo de su desistimiento — pedido {order_number}"

#: src/Mail/WooAckEmail.php:95 templates/emails/withdrawal-confirmation.php:30
msgid "Acknowledgement of receipt of your withdrawal"
msgstr "Acuse de recibo de su desistimiento"

