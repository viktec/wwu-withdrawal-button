msgid "Processed"
msgstr "Elaborato"

#: src/Admin/RequestsDashboard.php:242
msgid "Open"
msgstr "Aperto"

#: src/Admin/RequestsDashboard.php:260
msgid "Mark processed"
msgstr "Segna come elaborato"

#: src/Admin/RequestsDashboard.php:264
msgid "Resend email"
msgstr "Invia di nuovo l'e-mail"

#: src/Admin/RequestsDashboard.php:268
msgid "Open order (refund)"
msgstr "Ordine aperto (rimborso)"

#: src/Admin/RequestsDashboard.php:444
msgid "Request marked as processed."
msgstr "Richiesta contrassegnata come elaborata."

#: src/Admin/RequestsDashboard.php:445
msgid "Could not mark the request as processed — the order could not be loaded."
msgstr "Impossibile contrassegnare la richiesta come elaborata — l'ordine non ha potuto essere caricato."

#: src/Admin/RequestsDashboard.php:446
msgid "Acknowledgement email resent."
msgstr "E-mail di conferma inviata nuovamente."

#: src/Admin/RequestsDashboard.php:447
msgid "Could not resend the email — check your email/SMTP configuration."
msgstr "Impossibile inviare nuovamente l'e-mail — verifica la configurazione e-mail/SMTP."

#: src/Admin/RequestsDashboard.php:448
msgid "Please wait a few seconds before resending again."
msgstr "Attendi alcuni secondi prima di inviare di nuovo."

#: src/Admin/RequestsDashboard.php:74
msgid "A withdrawal is the consumer's unilateral right — there is nothing to approve. Once exercised within the period, reimburse the consumer within 14 days (same payment method). Use \"Refund order\" to issue the refund, then mark the request as processed."
msgstr "Il recesso è un diritto unilaterale del consumatore — non c'è nulla da approvare. Una volta esercitato entro il termine, rimborsa il consumatore entro 14 giorni (con lo stesso metodo di pagamento). Usa \"Rimborsa ordine\" per emettere il rimborso, quindi segna la richiesta come elaborata."

#: src/Admin/RequestsDashboard.php:80
msgid "Evidence log: chain intact"
msgstr "Log delle prove: catena integra"

#: src/Admin/RequestsDashboard.php:85
msgid "Evidence log: integrity broken at row #%d — investigate."
msgstr "Log delle prove: integrità compromessa alla riga n. %d — indaga."

#: src/Admin/RequestsDashboard.php:92
msgid "No withdrawal requests yet."
msgstr "Nessuna richiesta di recesso ancora."

#: src/Admin/RequestsDashboard.php:97
msgid "Date/time (submitted)"
msgstr "Data/ora (invio)"

#: src/Admin/RequestsDashboard.php:99
#: templates/emails/admin-notification.php:31
